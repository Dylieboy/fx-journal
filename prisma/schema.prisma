generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  trades   Trade[]
}

model Trade {
  id       String   @id @default(cuid())
  market   String
  lots     String
  date     String
  lose     Float
  target   Float
  actual   Float
  outcome  String
  setup    String
  notes    String
  userId   String
  user     User     @relation(fields: [userId], references: [id])
}